{
    "name": "momodemo333/dolibarr-mcp-server",
    "description": "MCP Server for Dolibarr ERP integration",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "ext-fileinfo": "*",
        "guzzlehttp/guzzle": "^7.10",
        "mcp/sdk": "^0.6",
        "symfony/finder": "^6.4",
        "webmozart/assert": "^1.11"
    },
    "autoload": {
        "psr-4": {
            "DolibarrMcp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DolibarrMcp\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "config": {
        "platform": {
            "php": "8.1.32"
        }
    }
}
